rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'isPro', 'credits']) &&
             data.uid is string &&
             (data.email == null || data.email is string) &&
             (data.displayName == null || data.displayName is string) &&
             (data.photoURL == null || data.photoURL is string) &&
             data.isPro is bool &&
             data.credits is number && data.credits >= 0;
    }

    function isValidProject(data) {
      return hasOnlyAllowedFields(['id', 'name', 'createdAt', 'updatedAt', 'userId']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is number &&
             data.updatedAt is number &&
             data.userId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      // Users can create their own profile, but cannot set themselves as Pro
      allow create: if isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       uidUnchanged() && 
                       request.resource.data.isPro == false;
      // Users can update their profile, but cannot modify isPro or credits directly
      allow update: if isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       uidNotModified() &&
                       request.resource.data.isPro == resource.data.isPro &&
                       request.resource.data.credits == resource.data.credits;
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                       isValidProject(request.resource.data) && 
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       isValidProject(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
